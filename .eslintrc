{
  "plugins": ["@vitest"],
  "extends": ["airbnb-base", "plugin:@vitest/legacy-recommended", "prettier"],
  "env": {
    "commonjs": true,
    "es6": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "prefer-destructuring": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "env": {
        "@vitest/env": true
      }
    }
  ]
}
