{
  "name": "action-get-or-create-release",
  "private": true,
  "description": "GitHub Action that creates a GitHub release",
  "engines": {
    "node": "^24.0.0"
  },
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "prebuild": "npm run lint && npm run test && npm run clean",
    "build": "esbuild src/main.js --bundle --platform=node --target=node24 --format=esm --outfile=dist/index.js --sourcemap --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\"",
    "debug": "node -r dotenv/config src/main.js",
    "clean": "shx rm -rf dist/*",
    "lint": "eslint . --cache --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "ISC",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@actions/glob": "^0.7.0",
    "bytes": "^3.1.2",
    "issue-parser": "^7.0.2",
    "mime-types": "^3.0.2",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.20",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.3",
    "shx": "^0.4.0",
    "vitest": "^4.1.9"
  }
}
